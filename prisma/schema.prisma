generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  trainer
  admin
  super_admin
}

enum BookingStatus {
  pending_payment
  confirmed
  cancelled
  completed
  no_show
}

enum BookingResourceType {
  court
  instructor
}

enum ScheduleResourceType {
  venue
  court
  instructor
}

enum ScheduleExceptionType {
  closed
  maintenance
}

enum PriceComponentType {
  court
  instructor
}

enum PricingPeriod {
  morning
  day
  evening_weekend
}

enum PaymentProvider {
  placeholder
  kaspi
  freedom
  manual
  wallet
}

enum PaymentStatus {
  unpaid
  paid
  failed
  refunded
}

enum WalletTransactionType {
  topup
  bonus
  admin_credit
  admin_debit
  booking_charge
  booking_refund
  event_charge
  event_refund
}

enum BookingHoldStatus {
  active
  converted
  expired
  cancelled
}

enum ClubEventStatus {
  draft
  published
  cancelled
}

enum EventRegistrationStatus {
  confirmed
  cancelled
}

enum VerificationPurpose {
  registration
  email_change
  phone_change
}

enum TelegramLinkPurpose {
  trainer_notifications
  admin_notifications
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  phone            String
  passwordHash     String
  role             UserRole  @default(customer)
  active           Boolean   @default(true)
  instructorId     String?   @unique
  walletBalance    Decimal   @default(0) @db.Decimal(12, 2)
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  telegramChatId   String?
  telegramUsername String?
  pendingEmail     String?
  pendingPhone     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bookings                  Booking[]                  @relation("CustomerBookings")
  instructor                Instructor?                @relation("TrainerUser", fields: [instructorId], references: [id], onDelete: SetNull)
  walletTransactions        WalletTransaction[]        @relation("WalletOwner")
  walletAdjustmentActions   WalletTransaction[]        @relation("WalletActor")
  bookingHolds              BookingHold[]              @relation("BookingHoldCustomer")
  eventRegistrations        EventRegistration[]        @relation("EventRegistrationCustomer")
  emailVerificationTokens   EmailVerificationToken[]
  emailVerificationCodes    EmailVerificationCode[]
  phoneVerificationSessions PhoneVerificationSession[]
  telegramLinkTokens        TelegramLinkToken[]
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model PhoneVerificationSession {
  id               String              @id @default(cuid())
  userId           String
  startToken       String              @unique
  purpose          VerificationPurpose @default(registration)
  targetPhone      String
  codeHash         String?
  codeSentAt       DateTime?
  codeAttemptCount Int                 @default(0)
  telegramChatId   String?
  telegramUserId   String?
  telegramUsername String?
  expiresAt        DateTime
  consumedAt       DateTime?
  createdAt        DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([telegramUserId, expiresAt])
}

model TelegramLinkToken {
  id         String              @id @default(cuid())
  userId     String
  purpose    TelegramLinkPurpose
  tokenHash  String              @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
}

model EmailVerificationCode {
  id           String              @id @default(cuid())
  userId       String
  purpose      VerificationPurpose @default(registration)
  targetEmail  String
  codeHash     String
  attemptCount Int                 @default(0)
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
  @@index([targetEmail, purpose, expiresAt])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String
  phone     String?
  email     String?
  timezone  String   @default("Asia/Almaty")
  mapUrl    String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courts              Court[]
  openingHours        OpeningHour[]
  componentPrices     ComponentPrice[]
  bookings            Booking[]
  bookingHolds        BookingHold[]
  services            Service[]
  scheduleExceptions  ScheduleException[]
  instructorLocations InstructorLocation[]
  clubEvents          ClubEvent[]
  clubEventSeries     ClubEventSeries[]
}

model Sport {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courts            Court[]
  services          Service[]
  instructorSports  InstructorSport[]
  componentPrices   ComponentPrice[]
  resourceSchedules ResourceSchedule[]
  clubEvents        ClubEvent[]
  clubEventSeries   ClubEventSeries[]
}

model Court {
  id         String   @id @default(cuid())
  name       String
  sportId    String
  locationId String
  active     Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sport           Sport            @relation(fields: [sportId], references: [id], onDelete: Restrict)
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Restrict)
  clubEventCourts ClubEventCourt[]

  @@index([locationId, active])
  @@index([locationId, sportId, active])
}

model Instructor {
  id        String   @id @default(cuid())
  name      String
  bio       String?
  photoUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructorSports    InstructorSport[]
  instructorLocations InstructorLocation[]
  trainerUser         User?                @relation("TrainerUser")
  clubEvents          ClubEvent[]
  clubEventSeries     ClubEventSeries[]
  instructorPhotos    InstructorPhoto[]
}

model InstructorPhoto {
  id           String   @id @default(cuid())
  instructorId String
  url          String
  altText      String?
  sortOrder    Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, url])
  @@index([instructorId, sortOrder])
}

model Service {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  sportId            String
  locationId         String?
  requiresCourt      Boolean  @default(true)
  requiresInstructor Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sport        Sport         @relation(fields: [sportId], references: [id], onDelete: Restrict)
  location     Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  bookings     Booking[]
  bookingHolds BookingHold[]

  @@index([locationId, active])
  @@index([locationId, sportId, active])
}

model OpeningHour {
  id         String  @id @default(cuid())
  locationId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  active     Boolean @default(true)

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, dayOfWeek])
  @@index([locationId, active])
}

model ResourceSchedule {
  id           String               @id @default(cuid())
  resourceType ScheduleResourceType
  resourceId   String
  dayOfWeek    Int
  startTime    String
  endTime      String
  active       Boolean              @default(true)
  sportId      String?
  weekStart    DateTime?            @db.Date

  sport Sport? @relation(fields: [sportId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId])
  @@index([dayOfWeek, active])
  @@index([sportId])
  @@index([resourceType, resourceId, weekStart])
}

model ScheduleException {
  id           String                @id @default(cuid())
  locationId   String?
  resourceType ScheduleResourceType
  resourceId   String?
  date         DateTime
  startTime    String
  endTime      String
  type         ScheduleExceptionType
  note         String?

  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId, date])
  @@index([locationId, date])
  @@index([date])
}

model Booking {
  id                   String        @id @default(cuid())
  customerId           String
  serviceId            String
  locationId           String
  startAt              DateTime
  endAt                DateTime
  status               BookingStatus
  currency             String        @default("KZT")
  priceTotal           Decimal       @db.Decimal(10, 2)
  pricingBreakdownJson Json
  cancelledBy          String? // "customer" | "admin" | "system" | "trainer"
  cancelledAt          DateTime?
  cancellationReason   String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  customer           User                @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Restrict)
  service            Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  location           Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  resources          BookingResource[]
  payment            Payment?
  walletTransactions WalletTransaction[]
  bookingHold        BookingHold?

  @@index([startAt, endAt, status])
  @@index([customerId, createdAt])
  @@index([serviceId, startAt])
  @@index([locationId, startAt])
}

model BookingResource {
  id           String              @id @default(cuid())
  bookingId    String
  resourceType BookingResourceType
  resourceId   String

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([resourceType, resourceId])
  @@index([bookingId])
}

model ComponentPrice {
  id            String             @id @default(cuid())
  locationId    String
  sportId       String
  componentType PriceComponentType
  period        PricingPeriod
  currency      String             @default("KZT")
  amount        Decimal            @db.Decimal(10, 2)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sport    Sport    @relation(fields: [sportId], references: [id], onDelete: Restrict)

  @@unique([locationId, sportId, componentType, period, currency])
  @@index([locationId, sportId, period])
}

model InstructorSport {
  id           String  @id @default(cuid())
  instructorId String
  sportId      String
  pricePerHour Decimal @db.Decimal(10, 2)

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  sport      Sport      @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([instructorId, sportId])
}

model InstructorLocation {
  id           String  @id @default(cuid())
  instructorId String
  locationId   String
  active       Boolean @default(true)

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([instructorId, locationId])
  @@index([locationId, active])
}

model Payment {
  id                String          @id @default(cuid())
  bookingId         String          @unique
  provider          PaymentProvider
  status            PaymentStatus
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("KZT")
  providerPaymentId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([provider, status])
}

model WalletBonusConfig {
  key          String   @id @default("default")
  thresholdKzt Decimal  @db.Decimal(10, 2)
  bonusPercent Int
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TelegramChannelConfig {
  key             String   @id @default("default")
  commonChatId    String?
  commonChatTitle String?
  enabled         Boolean  @default(true)
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model WalletTransaction {
  id                  String                @id @default(cuid())
  userId              String
  actorUserId         String?
  bookingId           String?
  holdId              String?
  eventRegistrationId String?
  type                WalletTransactionType
  amount              Decimal               @db.Decimal(12, 2)
  balanceAfter        Decimal               @db.Decimal(12, 2)
  currency            String                @default("KZT")
  note                String?
  metadataJson        Json?
  createdAt           DateTime              @default(now())

  user              User               @relation("WalletOwner", fields: [userId], references: [id], onDelete: Restrict)
  actorUser         User?              @relation("WalletActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  booking           Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  hold              BookingHold?       @relation(fields: [holdId], references: [id], onDelete: SetNull)
  eventRegistration EventRegistration? @relation(fields: [eventRegistrationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([bookingId])
  @@index([holdId])
  @@index([eventRegistrationId])
  @@index([type, createdAt])
}

model BookingHold {
  id                   String            @id @default(cuid())
  customerId           String
  serviceId            String
  locationId           String
  courtId              String?
  instructorId         String?
  convertedBookingId   String?           @unique
  startAt              DateTime
  endAt                DateTime
  amountRequired       Decimal           @db.Decimal(10, 2)
  currency             String            @default("KZT")
  pricingBreakdownJson Json
  status               BookingHoldStatus @default(active)
  expiresAt            DateTime
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  customer           User                @relation("BookingHoldCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  service            Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  location           Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  convertedBooking   Booking?            @relation(fields: [convertedBookingId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]

  @@index([customerId, status, expiresAt])
  @@index([locationId, startAt, endAt, status, expiresAt])
  @@index([courtId, startAt, endAt])
  @@index([instructorId, startAt, endAt])
}

model MediaAsset {
  id              String   @id @default(cuid())
  category        String   @default("gallery")
  url             String   @unique
  originalName    String?
  mimeType        String
  sizeBytes       Int
  altText         String?
  caption         String?
  active          Boolean  @default(true)
  sortOrder       Int      @default(100)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category, active, sortOrder])
  @@index([createdAt])
}

model ClubEventSeries {
  id              String   @id @default(cuid())
  title           String
  description     String?
  category        String   @default("group_training")
  level           String?
  sportId         String?
  locationId      String?
  instructorId    String?
  recurrence      String   @default("weekly")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sport      Sport?      @relation(fields: [sportId], references: [id], onDelete: SetNull)
  location   Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  instructor Instructor? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  events     ClubEvent[]

  @@index([sportId])
  @@index([locationId])
  @@index([instructorId])
}

model ClubEvent {
  id              String          @id @default(cuid())
  seriesId        String?
  title           String
  description     String?
  category        String          @default("group_training")
  level           String?
  sportId         String?
  locationId      String?
  instructorId    String?
  startsAt        DateTime
  endsAt          DateTime
  priceKzt        Decimal         @default(0) @db.Decimal(10, 2)
  capacity        Int
  status          ClubEventStatus @default(published)
  createdByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  series        ClubEventSeries?    @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  sport         Sport?              @relation(fields: [sportId], references: [id], onDelete: SetNull)
  location      Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  instructor    Instructor?         @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  courts        ClubEventCourt[]
  registrations EventRegistration[]

  @@index([status, startsAt])
  @@index([seriesId])
  @@index([sportId])
  @@index([locationId])
  @@index([instructorId])
}

model ClubEventCourt {
  id      String @id @default(cuid())
  eventId String
  courtId String

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  court Court     @relation(fields: [courtId], references: [id], onDelete: Restrict)

  @@unique([eventId, courtId])
  @@index([courtId])
  @@index([eventId])
}

model EventRegistration {
  id           String                  @id @default(cuid())
  eventId      String
  customerId   String
  status       EventRegistrationStatus @default(confirmed)
  pricePaidKzt Decimal                 @db.Decimal(10, 2)
  currency     String                  @default("KZT")
  cancelledAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  event              ClubEvent           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  customer           User                @relation("EventRegistrationCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  walletTransactions WalletTransaction[]

  @@unique([eventId, customerId])
  @@index([customerId, createdAt])
  @@index([eventId, status])
}

model AuditLog {
  id          String  @id @default(cuid())
  actorUserId String?
  action      String // e.g. "booking.cancel", "booking.status_change", "court.delete"
  entityType  String // "booking", "court", "instructor", "sport"
  entityId    String
  detail      Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}
